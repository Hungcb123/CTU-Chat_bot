                "label": "ocr_text",
                "bbox": [
                    472,
                    470,
                    1264,
                    525
                ],
                "score": 0.874,
                "text": "HIEU TRUONG TRUONG DAI HoC CAN THO"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    311,
                    1387,
                    1081,
                    1440
                ],
                "score": 0.925,
                "text": "Theo dè nghi cua Truóng phòng Cong tác Sinh vién."
            },
            {
                "label": "ocr_text",
                "bbox": [
                    310,
                    514,
                    1507,
                    565
                ],
                "score": 0.952,
                "text": "Cǎn cir Luàt Giáo duc dai hoc ngày 18 tháng 6 nǎm 2012 và Luàt sira aói, bó"
