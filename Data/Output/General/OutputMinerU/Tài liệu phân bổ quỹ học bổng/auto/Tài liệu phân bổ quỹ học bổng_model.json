            {
                "label": "ocr_text",
                "bbox": [
                    311,
                    1263,
                    1503,
                    1316
                ],
                "score": 0.937,
                "text": "Cǎn cir To trinh só 255/TTr-CTSV, ngày 25/07/2025 cua Phòng Cong tác Sinh"
