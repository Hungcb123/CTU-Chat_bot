            {
                "label": "ocr_text",
                "bbox": [
                    228,
                    559,
                    1309,
                    608
                ],
                "score": 0.958,
                "text": "sung mot só dièu cia Luàt Giáo duc dai hoc ngày 19 tháng 11 nǎm 2018;"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    312,
                    848,
                    1506,
                    900
                ],
                "score": 0.962,
                "text": "Cǎn cir Nghi dinh só 84/2020/ND-CP cüa Chinh phú ngày 17 tháng 7 nǎm 2020"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    227,
                    889,
                    944,
                    941
                ],
                "score": 0.929,
                "text": "quy dinh chi tiét mot só dièu cua Luat Giáo duc;"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    330,
                    1500,
                    1505,
                    1555
                ],
                "score": 0.951,
                "text": "Dièu 1. Quy dinh Hoc bóng khuyén khich cho sinh vièn dai hoc, hoc hinh thurc"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    233,
                    1549,
                    923,
                    1595
                ],
                "score": 0.99,
                "text": "chính quy tai truòng theo khói ngành nhu sau:"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    310,
                    596,
                    1507,
                    650
                ],
                "score": 0.971,
                "text": "Cǎn cir Nghi dinh só 99/2019/ND-CP cua Chinh phú ngày 30 tháng 12 nǎm 2019"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    228,
                    642,
                    1504,
                    693
                ],
                "score": 0.943,
                "text": "quy dinh chi tiét và huóng dān thi hành mōt só dièu cua Luàt sira dói, bó sung mōt só"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    231,
                    685,
                    721,
                    733
                ],
                "score": 0.949,
                "text": "dièu cua Luàt Giáo duc dai hoc;"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    311,
                    723,
                    1504,
                    777
                ],
                "score": 0.934,
                "text": "Cǎn cir Thong tr só 10/2016/TT-BGDDT ngày 05/4/2016 cua Bo trróng Bo Giáo"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    231,
                    768,
                    1506,
                    817
                ],
                "score": 0.964,
                "text": "duc và Dào tao Ban hành Quy ché cóng tác sinh vièn dói vói chuong trinh dào tao dai"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    230,
                    809,
                    915,
                    862
                ],
                "score": 0.939,
                "text": "hoc hé chinh quy và các vǎn ban có lièn quan;"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    310,
                    1134,
                    1503,
                    1195
                ],
                "score": 0.912,
                "text": "Cǎn cir Quy dinh vè cóng tác hoc vu dành cho sinh vién bàc dai hoc và cao dǎng"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    229,
                    1182,
                    1505,
                    1233
                ],
                "score": 0.968,
                "text": "he chinh quy, ban hành kèm theo Quyét dinh só 3266/QD–DHCT, ngày 15/8/2024 cua"
