            {
                "label": "ocr_text",
                "bbox": [
                    311,
                    929,
                    1506,
                    982
                ],
                "score": 0.967,
                "text": "Cǎn cir Nghi quyét só 99/NQ-HDT ngày 19 tháng 4 nǎm 2023 cua Hoi dòng"
            },
            {
                "label": "ocr_text",
                "bbox": [
                    231,
                    975,
                    1504,
                    1022
                ],
                "score": 0.945,
                "text": "Truòng ban hành Quy ché Tó chirc và hoat dong cia Truòng Dai hoc Càn Tho; Nghi"
