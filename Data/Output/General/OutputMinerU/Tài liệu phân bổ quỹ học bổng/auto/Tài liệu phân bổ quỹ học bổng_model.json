                "label": "ocr_text",
                "bbox": [
                    230,
                    1304,
                    1505,
                    1357
                ],
                "score": 0.949,
                "text": "vien vè dièu chinh dinh mirc hoc bóng khuyén khich áp dung tir hoc kj 1, nǎm hoc"
